#!/usr/bin/env bash

# xwrap: multicall, best-effort wrappers for fd/rg/sed for LLM-friendly inspection.
#
# Install:
#   ln -sf xwrap fd-x
#   ln -sf xwrap rg-x
#   ln -sf xwrap sed-x
#
# Or invoke directly:
#   ./xwrap fd-x ...
#   ./xwrap rg-x ...
#   ./xwrap sed-x ...

set -o pipefail

export LC_ALL=C LANG=C

MAX_FD_ROWS="${LLM_X_MAX_FD_ROWS:-200}"
MAX_RG_FILES="${LLM_X_MAX_RG_FILES:-80}"
MAX_RG_MATCH_LINES_PER_FILE="${LLM_X_MAX_RG_MATCH_LINES_PER_FILE:-4}"

SOFT_LINE_CHARS="${LLM_X_SOFT_LINE_CHARS:-400}"
HARD_LINE_CHARS="${LLM_X_HARD_LINE_CHARS:-2000}"
HEAD_CHARS="${LLM_X_HEAD_CHARS:-160}"
TAIL_CHARS="${LLM_X_TAIL_CHARS:-80}"

SEDX_STDIN_MAX_LINES="${LLM_X_SEDX_STDIN_MAX_LINES:-200000}"
SEDX_STDIN_MAX_BYTES="${LLM_X_SEDX_STDIN_MAX_BYTES:-10000000}"


escape_field() {
  local s="${1-}"
  s="${s//\\/\\\\}"
  s="${s//$'\t'/\\t}"
  s="${s//$'\n'/\\n}"
  s="${s//$'\r'/\\r}"
  printf '%s' "$s"
}

run_to_fifo() {
  RUN_FIFO=""
  RUN_PID=""
  RUN_TMPDIR=""

  local tmpdir fifo pid
  tmpdir="$(mktemp -d "${TMPDIR:-/tmp}/xwrap.XXXXXX")" || return 2
  fifo="$tmpdir/out"
  if ! mkfifo "$fifo"; then
    rm -rf "$tmpdir"
    return 2
  fi

  # Avoid FIFO open deadlocks: opening a FIFO for writing blocks until a reader exists.
  # Open a temporary RDWR fd so the writer redirection can succeed, then close it.
  if ! exec 9<>"$fifo"; then
    rm -rf "$tmpdir"
    return 2
  fi
  "$@" </dev/null >"$fifo" &
  pid=$!
  exec 9>&-

  RUN_FIFO="$fifo"
  RUN_PID="$pid"
  RUN_TMPDIR="$tmpdir"
  return 0
}


file_meta_row() {
  local p="${1-}"
  local kind bytes lines

  if [[ -f "$p" ]]; then
    kind="file"
    bytes="-"
    lines="-"
    local wc_out
    if wc_out="$(wc -c -l < "$p" 2>/dev/null)"; then
      # `wc -c -l < file` prints: "<lines> <bytes>"
      read -r lines bytes <<<"$wc_out"
    fi
  elif [[ -d "$p" ]]; then
    kind="dir"
    bytes="-"
    lines="-"
  elif [[ -L "$p" ]]; then
    kind="symlink"
    bytes="-"
    lines="-"
  elif [[ -e "$p" ]]; then
    kind="other"
    bytes="-"
    lines="-"
  else
    kind="missing"
    bytes="-"
    lines="-"
  fi

  if [[ "$kind" == "file" ]]; then
    printf '%s\tbytes=%s\tlines=%s\n' "$(escape_field "$p")" "$bytes" "$lines"
  else
    printf '%s\n' "$(escape_field "$p")"
  fi
}


classify_line_kind() {
  # echo one of: plain | long | json | base64
  local line="${1-}"
  local len=${#line}

  if (( len <= SOFT_LINE_CHARS )); then
    printf 'plain'
    return 0
  fi

  # JSON-ish
  if [[ "$line" =~ ^[[:space:]]*[\{\[] ]]; then
    printf 'json'
    return 0
  fi

  # base64-ish (no spaces, only base64 chars; cheap heuristic)
  if [[ "$line" != *" "* ]] && [[ "$line" =~ ^[A-Za-z0-9+/=_-]+$ ]]; then
    printf 'base64'
    return 0
  fi

  if (( len > HARD_LINE_CHARS )); then
    printf 'long'
    return 0
  fi

  printf 'plain'
}


truncated_marker() {
  local prefix="${1-}"
  local line="${2-}"
  local kind="${3-}"

  local len=${#line}
  local head="${line:0:HEAD_CHARS}"
  local tail=""
  if (( len > HEAD_CHARS )); then
    tail="${line: -TAIL_CHARS}"
  fi

  printf "[%s len=%s kind=%s head='%s' tail='%s']" \
    "$prefix" \
    "$len" \
    "$kind" \
    "$(escape_field "$head")" \
    "$(escape_field "$tail")"
}


render_maybe_gated_line() {
  # prints a single-line representation of $1 (no trailing newline)
  local line="${1-}"
  local kind
  kind="$(classify_line_kind "$line")"

  if [[ "$kind" == "plain" ]]; then
    printf '%s' "$(escape_field "$line")"
    return 0
  fi

  printf '%s' "$(truncated_marker "rg-x truncated" "$line" "$kind")"
}


fd_x_supported() {
  for a in "$@"; do
    case "$a" in
      -h|--help|-V|--version)
        return 1
        ;;
      -0|--print0|-l|--list-details|-x|-X|--exec|--exec-batch|--format|--format=*|--exec=*|--exec-batch=*)
        return 1
        ;;
    esac
  done
  return 0
}

fd_strip_color_args() {
  # Print NUL-separated args with any -c/--color flags removed (only before "--").
  local after_end_of_options=0

  while (( $# )); do
    local a="$1"
    shift

    if (( after_end_of_options )); then
      printf '%s\0' "$a"
      continue
    fi

    if [[ "$a" == "--" ]]; then
      after_end_of_options=1
      printf '%s\0' "$a"
      continue
    fi

    if [[ "$a" == "--color" ]] || [[ "$a" == "-c" ]]; then
      shift || true
      continue
    fi

    if [[ "$a" == --color=* ]] || [[ "$a" == -c* ]]; then
      continue
    fi

    printf '%s\0' "$a"
  done
}


fd_x() {
  local -a argv=()
  local a
  while IFS= read -r -d '' a; do
    argv+=("$a")
  done < <(fd_strip_color_args "$@")

  if ! fd_x_supported "${argv[@]}"; then
    exec fd --color=never "${argv[@]}"
  fi

  local total=0
  local printed=0

  local -a out_rows=()
  local fifo pid tmpdir
  if ! run_to_fifo fd --color=never -0 "${argv[@]}"; then
    exec fd --color=never "${argv[@]}"
  fi
  fifo="$RUN_FIFO"
  pid="$RUN_PID"
  tmpdir="$RUN_TMPDIR"

  while IFS= read -r -d '' p; do
    p="${p#./}"
    total=$((total + 1))

    if (( printed < MAX_FD_ROWS )); then
      printed=$((printed + 1))
      out_rows+=("$(file_meta_row "$p")")
    fi
  done <"$fifo"

  wait "$pid"
  local rc=$?
  rm -rf "$tmpdir"

  if (( rc != 0 )); then
    exec fd --color=never "${argv[@]}"
  fi

  if (( ${#out_rows[@]} > 0 )); then
    printf '%s\n' "${out_rows[@]}"
  fi
  local omitted=$((total - printed))
  printf '@meta\ttool=fd-x\ttotal=%s\tprinted=%s\tomitted=%s\n' "$total" "$printed" "$omitted"
  return "$rc"
}


rg_should_passthrough() {
  for a in "$@"; do
    case "$a" in
      --json|--passthru|--vimgrep|--null|-0|-c|--count|--count-matches|-o|--only-matching|-r|--replace|--replace=*|\
      -A|-B|-C|--after-context|--before-context|--context|--after-context=*|--before-context=*|--context=*|\
      --heading|--no-heading|--no-line-number|--no-column|--with-filename|--no-filename|-H|-h)
        return 0
        ;;
      -*) # conservative: avoid parsing context/replace/count/only-matching bundles
        if [[ "$a" == -A* ]] || [[ "$a" == -B* ]] || [[ "$a" == -C* ]]; then
          return 0
        fi
        if [[ "$a" == *"0"* ]] || [[ "$a" == *"c"* ]] || [[ "$a" == *"o"* ]]; then
          return 0
        fi
        ;;
    esac
  done
  return 1
}


rg_is_filelist_mode() {
  for a in "$@"; do
    case "$a" in
      --files|-l|--files-with-matches|-L|--files-without-match)
        return 0
        ;;
      -*)
        if [[ "$a" == *"l"* ]] || [[ "$a" == *"L"* ]]; then
          return 0
        fi
        ;;
    esac
  done
  return 1
}

rg_strip_color_args() {
  # Print NUL-separated args with any --color flags removed (only before "--").
  local after_end_of_options=0

  while (( $# )); do
    local a="$1"
    shift

    if (( after_end_of_options )); then
      printf '%s\0' "$a"
      continue
    fi

    if [[ "$a" == "--" ]]; then
      after_end_of_options=1
      printf '%s\0' "$a"
      continue
    fi

    if [[ "$a" == "--color" ]]; then
      shift || true
      continue
    fi

    if [[ "$a" == --color=* ]]; then
      continue
    fi

    printf '%s\0' "$a"
  done
}


rg_x_filelist() {
  local total=0
  local printed=0

  local -a out_rows=()
  local fifo pid tmpdir
  if ! run_to_fifo env -u RIPGREP_CONFIG_PATH rg --color=never -0 "$@"; then
    exec rg --color=never "$@"
  fi
  fifo="$RUN_FIFO"
  pid="$RUN_PID"
  tmpdir="$RUN_TMPDIR"

  while IFS= read -r -d '' p; do
    p="${p#./}"
    total=$((total + 1))

    if (( printed < MAX_FD_ROWS )); then
      printed=$((printed + 1))
      out_rows+=("$(file_meta_row "$p")")
    fi
  done <"$fifo"

  wait "$pid"
  local rc=$?
  rm -rf "$tmpdir"

  if (( rc == 2 )); then
    exec rg --color=never "$@"
  fi

  if (( ${#out_rows[@]} > 0 )); then
    printf '%s\n' "${out_rows[@]}"
  fi
  local omitted=$((total - printed))
  printf '@meta\ttool=rg-x\tmode=filelist\ttotal=%s\tprinted=%s\tomitted=%s\n' "$total" "$printed" "$omitted"
  return "$rc"
}


rg_x_match() {
  local files_seen=0
  local files_printed=0
  local match_lines_total=0
  local match_lines_printed=0
  local match_lines_omitted=0

  local current_path=""
  local current_hits=0
  local current_omitted=0
  local current_kind="missing"
  local current_bytes="-"
  local current_lines="-"
  local -a current_lines_out=()
  local -a out_lines=()

  flush_current() {
    if [[ -z "$current_path" ]]; then
      return 0
    fi

    files_seen=$((files_seen + 1))
    match_lines_total=$((match_lines_total + current_hits))

    if (( files_printed < MAX_RG_FILES )); then
      files_printed=$((files_printed + 1))

      out_lines+=(
        "$(
          printf '@file\tpath=%s' "$(escape_field "$current_path")"
          if [[ "$current_kind" != "file" ]]; then
            printf '\tkind=%s' "$current_kind"
          fi
          printf '\tbytes=%s\tlines=%s' "$current_bytes" "$current_lines"
          if (( current_omitted > 0 )); then
            printf '\thits=%s\tshown=%s\tomitted=%s' "$current_hits" "${#current_lines_out[@]}" "$current_omitted"
          fi
        )"
      )
      local ln
      for ln in "${current_lines_out[@]}"; do
        out_lines+=("$ln")
      done

      match_lines_printed=$((match_lines_printed + ${#current_lines_out[@]}))
      match_lines_omitted=$((match_lines_omitted + current_omitted))
    else
      # Entire file group omitted.
      match_lines_omitted=$((match_lines_omitted + current_hits))
    fi

    current_path=""
    current_hits=0
    current_omitted=0
    current_kind="missing"
    current_bytes="-"
    current_lines="-"
    current_lines_out=()
  }

  start_group() {
    local p="${1-}"
    current_path="$p"

    if [[ -f "$p" ]]; then
      current_kind="file"
      local wc_out
      if wc_out="$(wc -c -l < "$p" 2>/dev/null)"; then
        read -r current_lines current_bytes <<<"$wc_out"
      fi
    elif [[ -d "$p" ]]; then
      current_kind="dir"
    elif [[ -L "$p" ]]; then
      current_kind="symlink"
    elif [[ -e "$p" ]]; then
      current_kind="other"
    else
      current_kind="missing"
    fi
  }

  local fifo pid tmpdir
  if ! run_to_fifo env -u RIPGREP_CONFIG_PATH rg --color=never --null --no-heading --line-number --column "$@"; then
    exec rg --color=never "$@"
  fi
  fifo="$RUN_FIFO"
  pid="$RUN_PID"
  tmpdir="$RUN_TMPDIR"

  exec 3<"$fifo"
  while IFS= read -r -d '' p <&3; do
    local rest
    if ! IFS= read -r rest <&3; then
      rest=""
    fi

    p="${p#./}"

    if [[ "$p" != "$current_path" ]]; then
      flush_current
      start_group "$p"
    fi

    current_hits=$((current_hits + 1))

    if (( ${#current_lines_out[@]} < MAX_RG_MATCH_LINES_PER_FILE )); then
      local line_no col_no text rest2 rendered
      line_no="${rest%%:*}"
      rest2="${rest#*:}"
      col_no="${rest2%%:*}"
      text="${rest2#*:}"
      rendered="$(render_maybe_gated_line "$text")"
      current_lines_out+=("${line_no}:${col_no}:${rendered}")
    else
      current_omitted=$((current_omitted + 1))
    fi
  done
  exec 3<&-

  wait "$pid"
  local rc=$?
  rm -rf "$tmpdir"

  if (( rc == 2 )); then
    exec rg --color=never "$@"
  fi

  flush_current

  if (( ${#out_lines[@]} > 0 )); then
    printf '%s\n' "${out_lines[@]}"
  fi

  printf '@meta\ttool=rg-x\tmode=match\tfiles=%s\tprinted_files=%s\tomitted_files=%s\tmatch_lines=%s\tprinted_match_lines=%s\tomitted_match_lines=%s\n' \
    "$files_seen" \
    "$files_printed" \
    "$((files_seen - files_printed))" \
    "$match_lines_total" \
    "$match_lines_printed" \
    "$match_lines_omitted"

  return "$rc"
}


rg_x() {
  local -a argv=()
  local a
  while IFS= read -r -d '' a; do
    argv+=("$a")
  done < <(rg_strip_color_args "$@")

  if rg_should_passthrough "${argv[@]}"; then
    exec rg --color=never "${argv[@]}"
  fi

  if rg_is_filelist_mode "${argv[@]}"; then
    rg_x_filelist "${argv[@]}"
    return $?
  fi

  rg_x_match "${argv[@]}"
}


parse_sed_range_spec() {
  # echoes: "<start>\t<end>\t<file>" on success
  local -a argv=("$@")

  local quiet=0
  local script=""
  local file=""

  local i=0
  while (( i < ${#argv[@]} )); do
    local a="${argv[$i]}"
    if [[ "$a" == "-n" ]]; then
      quiet=1
    elif [[ "$a" == "-e" ]]; then
      i=$((i + 1))
      (( i < ${#argv[@]} )) || return 1
      [[ -z "$script" ]] || return 1
      script="${argv[$i]}"
    elif [[ "$a" == -e* ]]; then
      [[ -z "$script" ]] || return 1
      script="${a:2}"
    elif [[ "$a" == -* ]]; then
      return 1
    else
      if [[ -z "$script" ]]; then
        script="$a"
      elif [[ -z "$file" ]]; then
        file="$a"
      else
        return 1
      fi
    fi
    i=$((i + 1))
  done

  (( quiet == 1 )) || return 1
  [[ -n "$script" ]] || return 1
  if [[ -z "$file" ]]; then
    file="-"
  fi

  if [[ "$script" =~ ^[[:space:]]*([0-9]+)[[:space:]]*,[[:space:]]*([0-9]+)[[:space:]]*p[[:space:]]*$ ]]; then
    local start="${BASH_REMATCH[1]}"
    local end="${BASH_REMATCH[2]}"
    (( start >= 1 )) || return 1
    (( end >= start )) || return 1
    printf '%s\t%s\t%s' "$start" "$end" "$file"
    return 0
  fi

  return 1
}


sed_x() {
  local spec
  if ! spec="$(parse_sed_range_spec "$@")"; then
    exec sed "$@"
  fi

  local start end file
  IFS=$'\t' read -r start end file <<<"$spec"

  if [[ "$file" == "-" ]]; then
    local truncated=0
    local total_bytes=0
    local line_no=0
    local complete=1
    local reason=""
    local is_tty=0
    if [[ -t 0 ]]; then
      is_tty=1
    fi

    while true; do
      local line rc add_nl kind_line
      IFS= read -r line
      rc=$?
      if (( rc != 0 )); then
        [[ -n "$line" ]] || break
      fi

      line_no=$((line_no + 1))
      add_nl=0
      if (( rc == 0 )); then
        add_nl=1
      fi
      total_bytes=$((total_bytes + ${#line} + add_nl))

      if (( line_no >= start && line_no <= end )); then
        kind_line="$(classify_line_kind "$line")"
        if [[ "$kind_line" == "plain" ]]; then
          printf '%s\n' "$line"
        else
          truncated=$((truncated + 1))
          printf '%s\n' "$(truncated_marker "sed-x truncated line=${line_no}" "$line" "$kind_line")"
        fi
      fi

      if (( is_tty == 1 && line_no >= end )); then
        complete=0
        reason="tty"
        break
      fi

      if (( is_tty == 0 && line_no >= end )); then
        if (( line_no >= SEDX_STDIN_MAX_LINES || total_bytes >= SEDX_STDIN_MAX_BYTES )); then
          complete=0
          reason="cap"
          break
        fi
      fi
    done

    printf '@meta\ttool=sed-x\tsource=stdin\trange=%s..%s\tbytes=%s\tlines=%s\tcomplete=%s' \
      "$start" \
      "$end" \
      "$total_bytes" \
      "$line_no" \
      "$complete"
    if [[ -n "$reason" ]]; then
      printf '\treason=%s' "$reason"
    fi
    if (( truncated > 0 )); then
      printf '\ttruncated_lines=%s' "$truncated"
    fi
    printf '\n'
    return 0
  fi

  local bytes="-" lines="-" kind="missing"
  if [[ -f "$file" ]]; then
    kind="file"
    local wc_out
    if wc_out="$(wc -c -l < "$file" 2>/dev/null)"; then
      read -r lines bytes <<<"$wc_out"
    fi
  elif [[ -d "$file" ]]; then
    kind="dir"
  elif [[ -L "$file" ]]; then
    kind="symlink"
  elif [[ -e "$file" ]]; then
    kind="other"
  fi

  if [[ "$kind" != "file" ]]; then
    exec sed "$@"
  fi

  local truncated=0
  local line_no="$start"
  local -a out_lines=()

  local fifo pid tmpdir
  if ! run_to_fifo sed "$@"; then
    exec sed "$@"
  fi
  fifo="$RUN_FIFO"
  pid="$RUN_PID"
  tmpdir="$RUN_TMPDIR"

  while IFS= read -r line; do
    local kind_line
    kind_line="$(classify_line_kind "$line")"
    if [[ "$kind_line" == "plain" ]]; then
      out_lines+=("$line")
    else
      truncated=$((truncated + 1))
      out_lines+=("$(truncated_marker "sed-x truncated line=${line_no}" "$line" "$kind_line")")
    fi
    line_no=$((line_no + 1))
  done <"$fifo"

  wait "$pid"
  local rc=$?
  rm -rf "$tmpdir"

  if (( rc != 0 )); then
    exec sed "$@"
  fi

  if (( ${#out_lines[@]} > 0 )); then
    printf '%s\n' "${out_lines[@]}"
  fi

  if [[ "$kind" == "file" ]]; then
    if (( truncated > 0 )); then
      printf '@meta\ttool=sed-x\tpath=%s\tbytes=%s\tlines=%s\trange=%s..%s\ttruncated_lines=%s\n' \
        "$(escape_field "$file")" \
        "$bytes" \
        "$lines" \
        "$start" \
        "$end" \
        "$truncated"
    else
      printf '@meta\ttool=sed-x\tpath=%s\tbytes=%s\tlines=%s\trange=%s..%s\n' \
        "$(escape_field "$file")" \
        "$bytes" \
        "$lines" \
        "$start" \
        "$end"
    fi
  else
    if (( truncated > 0 )); then
      printf '@meta\ttool=sed-x\tpath=%s\tkind=%s\tbytes=%s\tlines=%s\trange=%s..%s\ttruncated_lines=%s\n' \
        "$(escape_field "$file")" \
        "$kind" \
        "$bytes" \
        "$lines" \
        "$start" \
        "$end" \
        "$truncated"
    else
      printf '@meta\ttool=sed-x\tpath=%s\tkind=%s\tbytes=%s\tlines=%s\trange=%s..%s\n' \
        "$(escape_field "$file")" \
        "$kind" \
        "$bytes" \
        "$lines" \
        "$start" \
        "$end"
    fi
  fi
  return "$rc"
}


dispatch() {
  local argv0="${0##*/}"

  case "$argv0" in
    fd-x) fd_x "$@" ;;
    rg-x) rg_x "$@" ;;
    sed-x) sed_x "$@" ;;
    xwrap|xwrap.sh|xwrap.bash|xwrap.bash.sh|xwrap.bashscript|xwrap_script|xwrap-script|xwrap-wrapper|xwrap_wrapper)
      local sub="${1-}"
      shift 2>/dev/null || true
      case "$sub" in
        fd-x|fd) fd_x "$@" ;;
        rg-x|rg) rg_x "$@" ;;
        sed-x|sed) sed_x "$@" ;;
        *)
          printf 'usage: %s {fd-x|rg-x|sed-x} [args...]\n' "$argv0" >&2
          return 2
          ;;
      esac
      ;;
    *)
      # Unknown personality: passthrough to avoid breaking anything.
      exec "$argv0" "$@"
      ;;
  esac
}


dispatch "$@"
